# Opsional, isi salah satu atau lebih. Urutan pemakaian: rapidapi -> socialkit -> fallback DIY

# API key dari rapidapi.com, subscribe ke API "instagram120", dipakai lebih dulu, mendukung foto dan video
RAPIDAPI_KEY=

# API key dari socialkit.dev, fallback kedua, khusus video/reel
SOCIALKIT_ACCESS_KEY=

# Cookie sessionid dari akun instagram kamu sendiri, dipakai untuk fallback scraping langsung terakhir
INSTAGRAM_SESSIONID=
